# Copy this file to release.env for local release/image maintenance.
# release.env is intentionally gitignored because it may contain account-specific values.

# Docker image ownership. For a personal Docker Hub account, use your Docker Hub username.
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE_NAMESPACE=sheetaldharshan

# Docker image names.
JSON_BOOTSTRAP_IMAGE_NAME=exasol-json-bootstrap
MCP_SERVER_IMAGE_NAME=exasol-mcp-server

# Stable image tags used by scripts/build-images.js and scripts/set-image-namespace.js.
JSON_BOOTSTRAP_TAG=0.1.1
MCP_SERVER_TAG=0.1.0

# npm package identity used by maintainer docs/scripts that need to print install commands.
NPM_PACKAGE_NAME=@sheetaldharshan/exasol-json-mcp